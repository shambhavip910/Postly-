<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Postly</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-zinc-900 min-h-screen text-white flex items-center justify-center">
    <div class="w-full max-w-md px-8 py-12 bg-zinc-800 rounded-2xl">
        <h1 class="text-3xl font-bold mb-1">Postly</h1>
        <p class="text-zinc-400 text-sm mb-8">welcome back.</p>
        <form action="/login" method="post" class="flex flex-col gap-3">
            <input class="bg-zinc-700 text-sm placeholder-zinc-500 px-4 py-3 rounded-lg outline-none focus:ring-2 focus:ring-indigo-500" type="text" placeholder="email" name="email">
            <input class="bg-zinc-700 text-sm placeholder-zinc-500 px-4 py-3 rounded-lg outline-none focus:ring-2 focus:ring-indigo-500" type="password" placeholder="password" name="password">
            <button type="submit" class="bg-indigo-600 hover:bg-indigo-500 text-sm font-semibold py-3 rounded-lg mt-1">Login</button>
        </form>
        <p class="text-zinc-500 text-sm mt-5 text-center">New user? <a class="text-indigo-400 hover:underline" href="/">Register here</a></p>
    </div>
</body>
</html>