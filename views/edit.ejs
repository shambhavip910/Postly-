<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Postly</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-zinc-900 min-h-screen text-white">

    <header class="bg-zinc-800 px-8 py-4 flex items-center justify-between border-b border-zinc-700">
        <h1 class="text-lg font-bold">Postly</h1>
        <a href="/profile" class="text-sm text-zinc-400 hover:text-indigo-400">← back</a>
    </header>

    <main class="max-w-xl mx-auto px-6 py-10">
        <h1 class="text-2xl font-bold mb-1">Edit Post</h1>
        <p class="text-zinc-500 text-sm mb-8">make your changes below.</p>

        <form action="/edit/<%= post.id %>" method="post" class="flex flex-col gap-3">
            <textarea name="content" rows="5" class="bg-zinc-800 border border-zinc-700 text-sm text-white placeholder-zinc-500 px-4 py-3 rounded-lg outline-none focus:ring-2 focus:ring-indigo-500 resize-none"><%= post.content %></textarea>
            <div class="flex justify-end">
                <button type="submit" class="bg-indigo-600 hover:bg-indigo-500 text-sm font-semibold px-6 py-2 rounded-lg">Update Post</button>
            </div>
        </form>
    </main>
</body>
</html>